///////////////////////////////////////////////////////////////
// GENERATOR & DATASOURCE
///////////////////////////////////////////////////////////////

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

///////////////////////////////////////////////////////////////
// ENUMS
///////////////////////////////////////////////////////////////

enum Role {
  USER         // usuário comum (interno, se quiser)
  ADMIN        // admin do laboratório (tenant admin)
  SUPER_ADMIN  // dono do SaaS
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  EXPIRED
}

enum AnalysisType {
  AGUA
  SOLO
  AMBIENTAL
  CLINICO
  INDUSTRIAL
}

enum ReportStatus {
  VALIDO
  SUBSTITUIDO
  CANCELADO
  EM_ANALISE
}

enum ReportSection {
  FISICO_QUIMICO
  MICROBIOLOGICO
}

enum ProductType {
  REAGENT     // reagente
  MATERIAL    // material de consumo
  EQUIPMENT   // equipamento
  OTHER
}

///////////////////////////////////////////////////////////////
// LOCATION (OPCIONAL, MAS ÚTIL)
///////////////////////////////////////////////////////////////

model State {
  id        String   @id @default(uuid())
  name      String
  uf        String   @unique
  createdAt DateTime @default(now())

  cities City[]

  @@map("states")
}

model City {
  id        String   @id @default(uuid())
  name      String
  stateId   String   @map("state_id")
  createdAt DateTime @default(now())

  state State @relation(fields: [stateId], references: [id])

  stores Store[]

  @@unique([name, stateId])
  @@map("cities")
}

///////////////////////////////////////////////////////////////
// MULTI-TENANT (STORE = LABORATORY)
///////////////////////////////////////////////////////////////

model Store {
  id          String   @id @default(uuid())
  name        String
  slug        String?  @unique
  isActive    Boolean  @default(true)

  // dados do laboratório
  cnpj        String?
  phone       String?
  email       String?
  street      String?
  postalCode  String?  @map("postal_code")
  cityId      String?  @map("city_id")
  state       String?
  avatar      String?  // logo
  createdAt   DateTime @default(now()) @map("created_at")

  // assinatura do laboratório (imagem do responsável / carimbo)
  signatureImageUrl String? @map("signature_image_url")

  city City? @relation(fields: [cityId], references: [id])

  // multi-tenant relations
  users         User[]
  clients       Client[]
  reports       Report[]
  products      Product[]
  subscriptions Subscription[]

  // tipo(s) de laboratório
  storeBusinessCategories StoreBusinessCategory[]

  @@map("stores")
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String   @map("password_hash")
  role         Role     @default(USER)

  phone       String?
  cpf         String?
  avatar      String?
  createdAt   DateTime @default(now()) @map("created_at")

  // tenant scoping
  storeId String? @map("store_id")
  store   Store?  @relation(fields: [storeId], references: [id])

  refreshTokens RefreshToken[]

  @@index([storeId])
  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String   @map("user_id")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

///////////////////////////////////////////////////////////////
// SUBSCRIPTION / PLANS (SAAS)
///////////////////////////////////////////////////////////////

model Plan {
  id           String   @id
  name         String
  price        Decimal
  description  String?
  createdAt    DateTime @default(now()) @map("created_at")

  // limites do SaaS (ajuste como quiser)
  reportLimit  Int @default(1000) @map("report_limit")
  userLimit    Int @default(10)   @map("user_limit")
  storageGb    Int @default(5)    @map("storage_gb")

  subscriptions Subscription[]

  @@map("plans")
}

model Subscription {
  id        String             @id @default(uuid())
  storeId   String             @map("store_id")
  planId    String             @map("plan_id")
  status    SubscriptionStatus @default(ACTIVE)
  startAt   DateTime           @default(now()) @map("start_at")
  endAt     DateTime           @map("end_at")
  renewedAt DateTime?          @map("renewed_at")
  createdAt DateTime           @default(now()) @map("created_at")

  plan  Plan  @relation(fields: [planId], references: [id])
  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId])
  @@index([planId])
  @@map("subscriptions")
}

///////////////////////////////////////////////////////////////
// LAB TYPE (BUSINESS CATEGORY = TIPO DE LAB)
///////////////////////////////////////////////////////////////

model BusinessCategory {
  id        String   @id @default(uuid())
  name      String   @unique
  image     String?
  createdAt DateTime @default(now()) @map("created_at")

  stores StoreBusinessCategory[]

  @@map("business_categories")
}

model StoreBusinessCategory {
  id         String           @id @default(uuid())
  storeId    String           @map("store_id")
  categoryId String           @map("category_id")

  store    Store            @relation(fields: [storeId], references: [id], onDelete: Cascade)
  category BusinessCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([storeId, categoryId])
  @@index([storeId])
  @@index([categoryId])
  @@map("store_business_categories")
}

///////////////////////////////////////////////////////////////
// CLIENTS (DOMÍNIO DO LAB)
///////////////////////////////////////////////////////////////

model Client {
  id        String   @id @default(uuid())
  storeId   String   @map("store_id")

  name      String
  email     String?
  document  String?  // CPF/CNPJ
  phone     String?
  company   String?
  address   String?
  municipality String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  store   Store   @relation(fields: [storeId], references: [id], onDelete: Cascade)
  reports Report[]

  // evita duplicar clientes no mesmo laboratório
  @@unique([storeId, document])
  @@index([storeId])
  @@map("clients")
}

///////////////////////////////////////////////////////////////
// REPORTS (LAUDOS)
///////////////////////////////////////////////////////////////

model Report {
  id        String      @id @default(uuid())
  storeId   String      @map("store_id")
  clientId  String?     @map("client_id")

  // Número do ensaio / número do laudo (pode ser gerado por sequência por store futuramente)
  reportNumber String?  @map("report_number")

  analysisType AnalysisType
  status       ReportStatus @default(EM_ANALISE)

  // datas
  sampleDate   DateTime? @map("sample_date")
  issueDate    DateTime? @map("issue_date")
  entryDate    DateTime? @map("entry_date")
  collectionTime String? @map("collection_time")

  // campos de amostra
  identification   String?
  location         String?
  collectionAgent  String? @map("collection_agent")

  // responsável técnico (pode vir do user/admin ou manual)
  responsibleTechnician  String? @map("responsible_technician")
  technicianRegistration String? @map("technician_registration")

  description String?

  // PDF assinado + URL pública (ex: /pdf/:filename)
  signedPdfUrl String? @map("signed_pdf_url")

  // base legal VMP / referência
  vmpReference String? @map("vmp_reference")

  // QRCode (opcional: pode gerar no backend e persistir)
  qrCodeUrl   String? @map("qr_code_url")
  publicUrl   String? @map("public_url")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  store  Store   @relation(fields: [storeId], references: [id], onDelete: Cascade)
  client Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)

  results ReportResultRow[]

  @@index([storeId])
  @@index([clientId])
  @@map("reports")
}

model ReportResultRow {
  id        String        @id @default(uuid())
  reportId  String        @map("report_id")
  section   ReportSection

  // linha de ensaio
  parameter String
  result    String
  unit      String?
  method    String?
  vmp       String? // valor máximo permitido, se quiser fixar por linha
  notes     String?

  order     Int? @default(0)

  createdAt DateTime @default(now()) @map("created_at")

  report Report @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([reportId])
  @@map("report_result_rows")
}

///////////////////////////////////////////////////////////////
// STOCK / REAGENTS (REUSANDO PRODUCT/CATEGORY/SUBCATEGORY)
///////////////////////////////////////////////////////////////

model Category {
  id        String   @id @default(uuid())
  name      String   @unique
  image     String?
  createdAt DateTime @default(now()) @map("created_at")

  subcategories SubCategory[]

  @@map("categories")
}

model SubCategory {
  id         String   @id @default(uuid())
  name       String
  image      String?
  categoryId String   @map("category_id")
  createdAt  DateTime @default(now()) @map("created_at")

  category Category  @relation(fields: [categoryId], references: [id])
  products Product[]

  @@unique([name, categoryId])
  @@map("subcategories")
}

model Product {
  id            String      @id @default(uuid())
  storeId       String      @map("store_id")
  subcategoryId String      @map("subcategory_id")

  type          ProductType @default(REAGENT)

  name          String
  description   String?
  quantity      Decimal     @default(0) // estoque atual
  minStock      Int         @default(5)
  unit          String?     // ex: "mL", "g", "un", "frasco"
  lotNumber     String?     @map("lot_number")
  expiresAt     DateTime?   @map("expires_at")

  image         String?
  status        Boolean     @default(true)

  createdAt     DateTime    @default(now()) @map("created_at")

  store       Store       @relation(fields: [storeId], references: [id], onDelete: Cascade)
  subcategory SubCategory @relation(fields: [subcategoryId], references: [id])

  @@index([storeId])
  @@index([subcategoryId])
  @@map("products")
}