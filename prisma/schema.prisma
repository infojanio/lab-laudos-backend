///////////////////////////////////////////////////////////////
// GENERATOR & DATASOURCE
///////////////////////////////////////////////////////////////

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

///////////////////////////////////////////////////////////////
// ENUMS
///////////////////////////////////////////////////////////////

enum Role {
  USER
  ADMIN
  SUPER_ADMIN
  TECHNICIAN
  VIEWER
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  EXPIRED
  TRIALING
}

enum AnalysisType {
  AGUA
  SOLO
  AMBIENTAL
  CLINICO
  INDUSTRIAL
}

enum ReportStatus {
  EM_ANALISE
  VALIDO
  SUBSTITUIDO
  CANCELADO
}

enum ReportSection {
  FISICO_QUIMICO
  MICROBIOLOGICO
}

enum SampleStatus {
  RECEIVED
  IN_ANALYSIS
  COMPLETED
  REPORTED
  CANCELED
}

enum ProductType {
  REAGENT
  MATERIAL
  EQUIPMENT
  OTHER
}

///////////////////////////////////////////////////////////////
// LOCATION
///////////////////////////////////////////////////////////////

model State {
  id        String   @id @default(uuid())
  name      String
  uf        String   @unique
  createdAt DateTime @default(now())

  cities City[]

  @@map("states")
}

model City {
  id        String   @id @default(uuid())
  name      String
  stateId   String   @map("state_id")
  createdAt DateTime @default(now())

  state  State   @relation(fields: [stateId], references: [id])
  stores Store[]

  @@unique([name, stateId])
  @@index([stateId])
  @@map("cities")
}

///////////////////////////////////////////////////////////////
// MULTI-TENANT (STORE = LABORATORY)
///////////////////////////////////////////////////////////////

model Store {
  id       String  @id @default(uuid())
  name     String
  slug     String  @unique
  isActive Boolean @default(true)

  // branding / identidade do laboratório
  cnpj         String?
  phone        String?
  email        String?
  street       String?
  postalCode   String? @map("postal_code")
  cityId       String? @map("city_id")
  state        String?
  logoUrl      String? @map("logo_url")
  avatar       String?
  primaryColor String? @map("primary_color")

  // responsável técnico padrão
  responsibleTechnician  String? @map("responsible_technician")
  technicianRegistration String? @map("technician_registration")
  signatureImageUrl      String? @map("signature_image_url")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @map("updated_at")

  city City? @relation(fields: [cityId], references: [id])

  // multi-tenant relations
  users                   User[]
  clients                 Client[]
  samples                 Sample[]
  reports                 Report[]
  labParameters           LabParameter[]
  products                Product[]
  subscriptions           Subscription[]
  auditLogs               AuditLog[]
  storeBusinessCategories StoreBusinessCategory[]

  @@index([cityId])
  @@map("stores")
}

///////////////////////////////////////////////////////////////
// USERS / AUTH
///////////////////////////////////////////////////////////////

model User {
  id           String @id @default(uuid())
  name         String
  email        String @unique
  passwordHash String @map("password_hash")
  role         Role   @default(USER)

  phone     String?
  cpf       String?
  avatar    String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @map("updated_at")

  // tenant scoping
  storeId String? @map("store_id")
  store   Store?  @relation(fields: [storeId], references: [id], onDelete: SetNull)

  refreshTokens RefreshToken[]
  auditLogs     AuditLog[]

  @@index([storeId])
  @@index([role])
  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String   @map("user_id")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

///////////////////////////////////////////////////////////////
// SUBSCRIPTION / PLANS (SAAS)
///////////////////////////////////////////////////////////////

model Plan {
  id          String   @id
  name        String
  price       Decimal
  description String?
  createdAt   DateTime @default(now()) @map("created_at")

  reportLimit Int @default(1000) @map("report_limit")
  userLimit   Int @default(10) @map("user_limit")
  storageGb   Int @default(5) @map("storage_gb")

  subscriptions Subscription[]

  @@map("plans")
}

model Subscription {
  id        String             @id @default(uuid())
  storeId   String             @map("store_id")
  planId    String             @map("plan_id")
  status    SubscriptionStatus @default(ACTIVE)
  startAt   DateTime           @default(now()) @map("start_at")
  endAt     DateTime           @map("end_at")
  renewedAt DateTime?          @map("renewed_at")
  createdAt DateTime           @default(now()) @map("created_at")
  updatedAt DateTime           @updatedAt @map("updated_at")

  plan  Plan  @relation(fields: [planId], references: [id])
  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId])
  @@index([planId])
  @@index([status])
  @@map("subscriptions")
}

///////////////////////////////////////////////////////////////
// LAB TYPE / BUSINESS CATEGORY
///////////////////////////////////////////////////////////////

model BusinessCategory {
  id        String   @id @default(uuid())
  name      String   @unique
  image     String?
  createdAt DateTime @default(now()) @map("created_at")

  stores StoreBusinessCategory[]

  @@map("business_categories")
}

model StoreBusinessCategory {
  id         String @id @default(uuid())
  storeId    String @map("store_id")
  categoryId String @map("category_id")

  store    Store            @relation(fields: [storeId], references: [id], onDelete: Cascade)
  category BusinessCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([storeId, categoryId])
  @@index([storeId])
  @@index([categoryId])
  @@map("store_business_categories")
}

///////////////////////////////////////////////////////////////
// CLIENTS
///////////////////////////////////////////////////////////////

model Client {
  id      String @id @default(uuid())
  storeId String @map("store_id")

  name         String
  email        String?
  document     String?
  phone        String?
  company      String?
  address      String?
  municipality String?

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  store   Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  samples Sample[]
  reports Report[]

  @@unique([storeId, document])
  @@index([storeId])
  @@index([storeId, name])
  @@map("clients")
}

///////////////////////////////////////////////////////////////
// SAMPLE TRACKING
///////////////////////////////////////////////////////////////

model Sample {
  id       String  @id @default(uuid())
  storeId  String  @map("store_id")
  clientId String? @map("client_id")

  code           String
  identification String?
  location       String?

  collectionDate DateTime? @map("collection_date")
  receivedDate   DateTime? @map("received_date")
  collectorName  String?   @map("collector_name")

  latitude  String?
  longitude String?

  weatherCondition   String? @map("weather_condition")
  ambientTemperature String? @map("ambient_temperature")

  status SampleStatus @default(RECEIVED)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  store   Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  client  Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)
  reports Report[]

  @@unique([storeId, code])
  @@index([storeId])
  @@index([clientId])
  @@index([status])
  @@map("samples")
}

///////////////////////////////////////////////////////////////
// LAB PARAMETER LIBRARY
///////////////////////////////////////////////////////////////

model LabParameter {
  id      String @id @default(uuid())
  storeId String @map("store_id")

  name    String
  section ReportSection
  unit    String?
  method  String?
  vmp     String?

  isActive Boolean @default(true)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, name, section])
  @@index([storeId])
  @@index([section])
  @@map("lab_parameters")
}

///////////////////////////////////////////////////////////////
// REPORTS
///////////////////////////////////////////////////////////////

model Report {
  id       String  @id @default(uuid())
  storeId  String  @map("store_id")
  clientId String? @map("client_id")
  sampleId String? @map("sample_id")

  reportNumber String? @map("report_number")
  sequence     Int?

  analysisType AnalysisType
  status       ReportStatus @default(EM_ANALISE)

  sampleDate     DateTime? @map("sample_date")
  issueDate      DateTime? @map("issue_date")
  entryDate      DateTime? @map("entry_date")
  collectionTime String?   @map("collection_time")

  identification  String?
  location        String?
  collectionAgent String? @map("collection_agent")

  responsibleTechnician  String? @map("responsible_technician")
  technicianRegistration String? @map("technician_registration")

  description  String?
  observations String?

  signedPdfUrl String? @map("signed_pdf_url")
  qrCodeUrl    String? @map("qr_code_url")
  publicUrl    String? @map("public_url")

  vmpReference String? @map("vmp_reference")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  store  Store   @relation(fields: [storeId], references: [id], onDelete: Cascade)
  client Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)
  sample Sample? @relation(fields: [sampleId], references: [id], onDelete: SetNull)

  results ReportResultRow[]

  @@index([storeId])
  @@index([clientId])
  @@index([sampleId])
  @@index([storeId, createdAt])
  @@index([status])
  @@map("reports")
}

model ReportResultRow {
  id       String        @id @default(uuid())
  reportId String        @map("report_id")
  section  ReportSection

  parameter String
  result    String
  unit      String?
  method    String?
  vmp       String?
  notes     String?

  order Int? @default(0)

  createdAt DateTime @default(now()) @map("created_at")

  report Report @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([reportId])
  @@index([section])
  @@map("report_result_rows")
}

///////////////////////////////////////////////////////////////
// STOCK / INVENTORY
///////////////////////////////////////////////////////////////

model Category {
  id        String   @id @default(uuid())
  name      String   @unique
  image     String?
  createdAt DateTime @default(now()) @map("created_at")

  subcategories SubCategory[]

  @@map("categories")
}

model SubCategory {
  id         String   @id @default(uuid())
  name       String
  image      String?
  categoryId String   @map("category_id")
  createdAt  DateTime @default(now()) @map("created_at")

  category Category  @relation(fields: [categoryId], references: [id])
  products Product[]

  @@unique([name, categoryId])
  @@index([categoryId])
  @@map("subcategories")
}

model Product {
  id            String @id @default(uuid())
  storeId       String @map("store_id")
  subcategoryId String @map("subcategory_id")

  type ProductType @default(REAGENT)

  name        String
  description String?
  quantity    Decimal   @default(0)
  minStock    Int       @default(5)
  unit        String?
  lotNumber   String?   @map("lot_number")
  expiresAt   DateTime? @map("expires_at")

  image  String?
  status Boolean @default(true)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  store       Store       @relation(fields: [storeId], references: [id], onDelete: Cascade)
  subcategory SubCategory @relation(fields: [subcategoryId], references: [id])

  @@unique([storeId, name])
  @@index([storeId])
  @@index([subcategoryId])
  @@map("products")
}

///////////////////////////////////////////////////////////////
// AUDIT LOGS
///////////////////////////////////////////////////////////////

model AuditLog {
  id      String  @id @default(uuid())
  storeId String  @map("store_id")
  userId  String? @map("user_id")

  entity   String
  entityId String
  action   String
  payload  Json?

  createdAt DateTime @default(now()) @map("created_at")

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)
  user  User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([storeId])
  @@index([userId])
  @@index([entity, entityId])
  @@map("audit_logs")
}
